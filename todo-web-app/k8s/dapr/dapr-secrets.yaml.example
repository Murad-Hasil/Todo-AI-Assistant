# [Task]: T-5.1.1 — dapr-secrets Kubernetes Secret
#
# INSTRUCTIONS:
#   1. Copy this file:  cp dapr-secrets.yaml.example dapr-secrets.yaml
#   2. Fill in the FOUR values below with your real credentials
#   3. Apply:           kubectl apply -f dapr-secrets.yaml
#   4. Verify:          kubectl get secret dapr-secrets
#
# WARNING: dapr-secrets.yaml is gitignored — NEVER commit it.
# This example file IS committed (contains no real values).

apiVersion: v1
kind: Secret
metadata:
  name: dapr-secrets
  namespace: default
type: Opaque
stringData:
  # Redpanda Cloud — Kafka Bootstrap Server
  # Example format: "seed-xxxx.cloud.redpanda.com:9092"
  REDPANDA_BOOTSTRAP_SERVER: "PASTE_BOOTSTRAP_SERVER_HERE"

  # Redpanda Cloud — SASL Username
  REDPANDA_USERNAME: "PASTE_SASL_USERNAME_HERE"

  # Redpanda Cloud — SASL Password
  REDPANDA_PASSWORD: "PASTE_SASL_PASSWORD_HERE"

  # Neon PostgreSQL — same DATABASE_URL as in secrets.values.yaml
  # Example format: "postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require"
  DATABASE_URL: "PASTE_NEON_DATABASE_URL_HERE"
