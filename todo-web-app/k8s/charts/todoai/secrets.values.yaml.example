# [Task]: T-4.9b
# Copy this file to secrets.values.yaml and fill in real values.
# secrets.values.yaml is listed in .gitignore — NEVER commit it.
#
# Usage: helm upgrade --install todoai ./todo-web-app/k8s/charts/todoai \
#          --values todo-web-app/k8s/charts/todoai/secrets.values.yaml
#
# Step 0 — get your Minikube IP:  minikube ip
# Replace 192.168.49.2 below with the actual output of `minikube ip`.
#
# NEXT_PUBLIC_API_URL is NOT set here — it is baked into the frontend Docker image
# at build time via --build-arg NEXT_PUBLIC_API_URL=http://$(minikube ip):30800

backend:
  secret:
    DATABASE_URL: "postgresql://user:password@host/dbname?sslmode=require"
    BETTER_AUTH_SECRET: "your-better-auth-secret-here"
    GROQ_API_KEY: "gsk_your_groq_api_key_here"
    # Allow the frontend NodePort origin — replace 192.168.49.2 with your `minikube ip`
    CORS_ORIGINS: "http://192.168.49.2:30300"

frontend:
  # Public URL of the Next.js app — used by Better Auth for redirects and CSRF checks.
  # Replace 192.168.49.2 with your `minikube ip`.
  betterAuthUrl: "http://192.168.49.2:30300"

