# [Task]: T-4.9b
# Copy this file to secrets.values.yaml and fill in real values.
# secrets.values.yaml is listed in .gitignore — NEVER commit it.
#
# Usage: helm upgrade --install todoai ./todo-web-app/k8s/charts/todoai --values secrets.values.yaml
#
# Get minikube IP: minikube ip
# Replace 192.168.49.2 with your actual minikube ip in CORS_ORIGINS below.

backend:
  secret:
    DATABASE_URL: "postgresql://user:password@host/dbname?sslmode=require"
    BETTER_AUTH_SECRET: "your-better-auth-secret-here"
    GROQ_API_KEY: "gsk_your_groq_api_key_here"
    nextPublicApiUrl: "http://localhost:8000"

frontend:
  # The public URL of the Next.js app — used by Better Auth for redirects and CSRF checks
  # Must match: http://$(minikube ip):30300
  betterAuthUrl: "http://localhost:3000"
