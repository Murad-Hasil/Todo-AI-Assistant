# [Task]: T-2.3.2
# Environment variables for Phase 2.3 Next.js Frontend
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to source control.

# Better Auth secret — must match the backend BETTER_AUTH_SECRET exactly
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-here-must-match-backend

# The base URL where this Next.js app is served (used by Better Auth internally)
BETTER_AUTH_URL=http://localhost:3000

# Neon Serverless PostgreSQL connection string (for Better Auth user/session tables)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# FastAPI backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Comma-separated list of additional trusted origins for Better Auth (CSRF protection)
# Add all Vercel deployment URLs that should be allowed to sign in
# Example: https://your-app.vercel.app,https://your-custom-domain.com
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
